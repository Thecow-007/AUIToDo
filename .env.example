PORT=7040

# Mongo
MONGODB_URI=
DB_NAME=AUIToDo

# Node
NODE_ENV=development

# Sessions
SESSION_SECRET=replace-me-with-a-long-random-string

# AI inference (Cerebras Cloud, OpenAI-compatible chat completions)
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gpt-oss-120b

# Embeddings (OpenAI)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Atlas Vector Search
# Name of the vector index defined in Atlas on the `todos.embedding` field.
# See server/services/embeddings.js for the index definition the code expects.
VECTOR_INDEX_NAME=todo_embedding_idx
